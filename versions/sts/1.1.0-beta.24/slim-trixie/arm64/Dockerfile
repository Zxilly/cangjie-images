FROM scratch AS sdk
ADD --checksum=sha256:3293f10fd0feaaa7febbafa2138a135589ea2de636bf277cc472dcf93cda9c2e \
    https://cangjie-lang.cn/v1/files/auth/downLoad?nsId=142267&fileName=cangjie-sdk-linux-aarch64-1.1.0-beta.24.tar.gz&objectKey=69c1028a6e8ed61e6e07fd35 \
    /sdk.tar.gz

FROM debian:bookworm-slim AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      --exclude='cangjie/lib/windows_*' \
      --exclude='cangjie/runtime/lib/windows_*' \
      --exclude='cangjie/modules/windows_*' \
      --exclude='cangjie/third_party/mingw' \
      --exclude='cangjie/lib/*.dll' \
      --exclude='cangjie/lib/*.dll.a'
EOF

FROM debian:trixie-slim
RUN <<'EOF'
set -eux
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
      ca-certificates \
      gcc \
      libc6-dev \
      libssl3
rm -rf /var/lib/apt/lists/*
EOF

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/linux_aarch64_cjnative:/opt/cangjie/tools/lib"
ENV PATH="/opt/cangjie/bin:/opt/cangjie/tools/bin:$PATH:/root/.cjpm/bin"

