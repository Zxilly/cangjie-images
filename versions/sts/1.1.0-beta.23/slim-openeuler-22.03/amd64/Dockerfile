FROM scratch AS sdk
ADD --checksum=sha256:cfd9f4e8b435b75be808484f120e81d0004b46b857567cd0ab84c32c458b6cf6 \
    https://cangjie-lang.cn/v1/files/auth/downLoad?nsId=142267&fileName=cangjie-sdk-linux-x64-1.1.0-beta.23.tar.gz&objectKey=69b7a52a6e8ed61e6e07fd2c \
    /sdk.tar.gz

FROM debian:bookworm-slim AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      --exclude='cangjie/lib/windows_*' \
      --exclude='cangjie/runtime/lib/windows_*' \
      --exclude='cangjie/modules/windows_*' \
      --exclude='cangjie/third_party/mingw' \
      --exclude='cangjie/lib/*.dll' \
      --exclude='cangjie/lib/*.dll.a'
EOF

FROM openeuler/openeuler:22.03-lts-sp4
RUN <<'EOF'
set -eux
sed -i.upstream -E '/^baseurl=/ s|https?://repo\.openeuler\.org|https://mirror.freedif.org/openEuler|' /etc/yum.repos.d/*.repo
dnf install -y --setopt=max_parallel_downloads=20 \
      ca-certificates \
      gcc \
      glibc-devel \
      openssl-libs
dnf clean all
rm -rf /var/cache/dnf
for f in /etc/yum.repos.d/*.repo.upstream; do mv -f "$f" "${f%.upstream}"; done
EOF

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/linux_x86_64_cjnative:/opt/cangjie/tools/lib"
ENV PATH="/opt/cangjie/bin:/opt/cangjie/tools/bin:$PATH:/root/.cjpm/bin"

