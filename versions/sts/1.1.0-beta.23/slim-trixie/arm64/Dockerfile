    https://cangjie-lang.cn/v1/files/auth/downLoad?nsId=142267&fileName=cangjie-sdk-linux-aarch64-1.1.0-beta.23.tar.gz&objectKey=69b7a69b6e8ed61e6e07fd2e \
    /sdk.tar.gz

FROM debian:bookworm-slim AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      --exclude='cangjie/lib/windows_*' \
      --exclude='cangjie/runtime/lib/windows_*' \
      --exclude='cangjie/modules/windows_*' \
      --exclude='cangjie/third_party/mingw' \
      --exclude='cangjie/lib/*.dll' \
      --exclude='cangjie/lib/*.dll.a'
EOF

FROM debian:trixie-slim
RUN <<'EOF'
set -eux
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
      bash \
      binutils \
      ca-certificates \
      curl \
      findutils \
      g++ \
      gcc \
      git \
      libc6-dev \
      libssl-dev \
      make \
      openssl \
      pkg-config \
      procps \
      tar \
      unzip \
      xz-utils \
      zip
rm -rf /var/lib/apt/lists/*
EOF

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/linux_aarch64_cjnative:/opt/cangjie/tools/lib"
