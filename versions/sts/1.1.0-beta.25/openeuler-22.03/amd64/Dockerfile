FROM scratch AS sdk
ADD --checksum=sha256:425390c4543ea2cd9e6c3a192f20ff34212b4328b4d2b5ca556f6953cb6acd13 \
    https://cangjie-lang.cn/v1/files/auth/downLoad?nsId=142267&fileName=cangjie-sdk-linux-x64-1.1.0-beta.25.tar.gz&objectKey=69cb718e6e8ed61e6e07fd42 \
    /sdk.tar.gz

FROM debian:bookworm-slim AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      --exclude='cangjie/lib/windows_*' \
      --exclude='cangjie/runtime/lib/windows_*' \
      --exclude='cangjie/modules/windows_*' \
      --exclude='cangjie/third_party/mingw' \
      --exclude='cangjie/lib/*.dll' \
      --exclude='cangjie/lib/*.dll.a'
EOF

FROM openeuler/openeuler:22.03-lts-sp4
RUN <<'EOF'
set -eux
sed -i.upstream -E 's|https?://repo\.openeuler\.org|https://mirrors.ocf.berkeley.edu/openeuler|g' /etc/yum.repos.d/*.repo
dnf install -y \
      bash \
      binutils \
      ca-certificates \
      curl \
      findutils \
      gcc \
      gcc-c++ \
      git \
      glibc-devel \
      make \
      openssl \
      openssl-devel \
      pkgconfig \
      procps-ng \
      tar \
      unzip \
      xz \
      zip
dnf clean all
rm -rf /var/cache/dnf
for f in /etc/yum.repos.d/*.repo.upstream; do mv -f "$f" "${f%.upstream}"; done
EOF

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/linux_x86_64_cjnative:/opt/cangjie/tools/lib"
