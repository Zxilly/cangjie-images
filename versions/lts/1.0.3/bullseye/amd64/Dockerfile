FROM scratch AS sdk
ADD --checksum=sha256:0f1312d337083b49e5ecec2554d35951af4aab88c712ce606249cfd79f3c30f6 \
    https://cangjie-lang.cn/v1/files/auth/downLoad?nsId=142267&fileName=cangjie-sdk-linux-x64-1.0.3.tar.gz&objectKey=68e725c23115f673ef1280fc \
    /sdk.tar.gz

FROM debian:bookworm-slim AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      --exclude='cangjie/lib/windows_*' \
      --exclude='cangjie/runtime/lib/windows_*' \
      --exclude='cangjie/modules/windows_*' \
      --exclude='cangjie/third_party/mingw' \
      --exclude='cangjie/lib/*.dll' \
      --exclude='cangjie/lib/*.dll.a'
EOF

FROM debian:bullseye
RUN <<'EOF'
set -eux
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
      bash \
      binutils \
      ca-certificates \
      curl \
      findutils \
      g++ \
      gcc \
      git \
      libc6-dev \
      libssl-dev \
      make \
      openssl \
      pkg-config \
      procps \
      tar \
      unzip \
      xz-utils \
      zip
rm -rf /var/lib/apt/lists/*
EOF

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/linux_x86_64_llvm:/opt/cangjie/tools/lib"
ENV PATH="/opt/cangjie/bin:/opt/cangjie/tools/bin:$PATH:/root/.cjpm/bin"

