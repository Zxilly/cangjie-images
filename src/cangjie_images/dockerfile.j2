{# Jinja2 template for a single-arch Cangjie Docker image.
   Context variables supplied by templates.render_dockerfile:
     channel, version, arch, base_name, base_image, base_family, slim,
     source (ArchSource), native_lib_token,
     packages_block, tar_excludes_block, extractor_image,
     repo_url, docs_url.
#}
# syntax=docker/dockerfile:1.7
# Generated by cangjie-images. Do not edit by hand.
# channel: {{ channel }}
# version: {{ version }}
# arch: {{ arch }}

FROM scratch AS sdk
ADD --checksum=sha256:{{ source.sha256 }} \
    {{ source.url }} \
    /sdk.tar.gz

FROM {{ extractor_image }} AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      {{ tar_excludes_block }}
EOF

FROM {{ base_image }}
{%- if packages_block and base_family == "debian" %}
RUN <<'EOF'
set -eux
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
      {{ packages_block }}
rm -rf /var/lib/apt/lists/*
EOF
{%- elif packages_block and base_family == "openeuler" %}
RUN <<'EOF'
set -eux
dnf install -y \
      {{ packages_block }}
dnf clean all
rm -rf /var/cache/dnf
EOF
{%- endif %}

COPY --from=extractor /out/ /

ENV CANGJIE_HOME="/opt/cangjie"
ENV LD_LIBRARY_PATH="/opt/cangjie/runtime/lib/{{ native_lib_token }}_{{ source.backend }}:/opt/cangjie/tools/lib"
ENV PATH="/opt/cangjie/bin:/opt/cangjie/tools/bin:$PATH:/root/.cjpm/bin"

LABEL org.opencontainers.image.title="Cangjie {{ version }} ({{ base_name }}/{{ arch }})"
LABEL org.opencontainers.image.description="Prebuilt Cangjie {{ channel | upper }} {{ version }} SDK on {{ base_name }} ({{ arch }}, {{ source.backend }} backend)"
LABEL org.opencontainers.image.version="{{ version }}"
LABEL org.opencontainers.image.source="{{ repo_url }}"
LABEL org.opencontainers.image.url="{{ repo_url }}"
LABEL org.opencontainers.image.documentation="{{ docs_url }}"
LABEL org.opencontainers.image.vendor="Zxilly"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.base.name="{{ base_image }}"
LABEL io.cangjie.channel="{{ channel }}"
LABEL io.cangjie.version="{{ version }}"
LABEL io.cangjie.arch="{{ arch }}"
LABEL io.cangjie.backend="{{ source.backend }}"
LABEL io.cangjie.base="{{ base_name }}"
LABEL io.cangjie.base.family="{{ base_family }}"
LABEL io.cangjie.slim="{{ 'true' if slim else 'false' }}"
LABEL io.cangjie.sdk.url="{{ source.url }}"
LABEL io.cangjie.sdk.sha256="{{ source.sha256 }}"

WORKDIR /workspace
CMD ["bash"]
