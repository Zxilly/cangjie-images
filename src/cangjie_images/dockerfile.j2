{# Jinja2 template for a single-arch Cangjie Docker image.
   Context variables supplied by templates.render_dockerfile:
     channel, version, arch, base_image, base_family,
     source (ArchSource), env_block,
     debian_packages_block, openeuler_packages_block,
     tar_excludes_block, extractor_image.
#}
# syntax=docker/dockerfile:1.7
# Generated by cangjie-images. Do not edit by hand.
# channel: {{ channel }}
# version: {{ version }}
# arch: {{ arch }}

FROM scratch AS sdk
ADD --checksum=sha256:{{ source.sha256 }} \
    {{ source.url }} \
    /sdk.tar.gz

FROM {{ extractor_image }} AS extractor
RUN --mount=from=sdk,source=/sdk.tar.gz,target=/sdk.tar.gz <<'EOF'
set -eux
mkdir -p /out/opt
tar -xzf /sdk.tar.gz -C /out/opt \
      {{ tar_excludes_block }}
EOF

FROM {{ base_image }}
{%- if base_family == "debian" %}
RUN <<'EOF'
set -eux
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
      {{ debian_packages_block }}
rm -rf /var/lib/apt/lists/*
EOF
{%- elif base_family == "openeuler" %}
RUN <<'EOF'
set -eux
dnf install -y \
      {{ openeuler_packages_block }}
dnf clean all
rm -rf /var/cache/dnf
EOF
{%- endif %}

COPY --from=extractor /out/ /

{{ env_block }}

LABEL org.opencontainers.image.title="Cangjie"
LABEL org.opencontainers.image.description="Prebuilt Cangjie SDK image"
LABEL io.cangjie.channel="{{ channel }}"
LABEL io.cangjie.version="{{ version }}"
LABEL io.cangjie.arch="{{ arch }}"

WORKDIR /workspace
CMD ["bash"]
